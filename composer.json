{
    "name": "lattice/workflow-store",
    "description": "Database-backed workflow event history persistence for LatticePHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "lattice/workflow": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\WorkflowStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\WorkflowStore\\Tests\\": "tests/"
        }
    }
}
