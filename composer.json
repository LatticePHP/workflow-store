{
    "name": "lattice/workflow-store",
    "description": "Database-backed workflow event history persistence for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "workflow",
        "event-store",
        "persistence",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/workflow-store"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/workflow": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\WorkflowStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\WorkflowStore\\Tests\\": "tests/"
        }
    }
}
